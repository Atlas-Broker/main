# Atlas Backend — Environment Variables
# Copy this to .env and fill in your values
#
# CLERK_JWKS_URL: use the instance-specific public endpoint, NOT api.clerk.com/v1/jwks
# Format: https://<instance>.clerk.accounts.dev/.well-known/jwks.json
# Your instance domain is the base64-decoded part after pk_test_/pk_live_ in your publishable key.

# App
PORT=8000
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# Render — set automatically by Render on deploy, do not set manually
# Used by the keep-alive background task to prevent the free tier from sleeping
# RENDER_EXTERNAL_URL=https://your-service.onrender.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/atlas?retryWrites=true&w=majority
MONGODB_DB_NAME=atlas

# LLM — Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Model selection — change these to upgrade without touching code
# Options: gemini-2.0-flash-lite | gemini-2.0-flash | gemini-2.5-flash | gemini-2.5-pro
LLM_QUICK_MODEL=gemini-2.0-flash-lite
LLM_DEEP_MODEL=gemini-2.0-flash-lite

# Alpaca Paper Trading
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market Data
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Daily Watchlist Scheduler
# Set SCHEDULER_ENABLED=true to run the pipeline for ALL connected users at 9:30 AM ET.
# Each user runs with their own Alpaca credentials and their own boundary_mode from their profile.
# No hardcoded user IDs — active users are discovered from the broker_connections table.
SCHEDULER_ENABLED=false
WATCHLIST_TICKERS=AAPL,MSFT,TSLA,NVDA,META
