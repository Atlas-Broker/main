# Atlas — Environment Variables
# Copy this to .env.local and fill in your values

# Supabase (frontend uses anon key only — never use service key here)
NEXT_PUBLIC_SUPABASE_URL=https://qbbbuebbxueqclkrvoos.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Tell Clerk where our sign-in/sign-up pages live
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=atlas

# Inngest
# Production (Vercel UAT/prod): set both keys from app.inngest.com → Settings
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Local dev: set INNGEST_DEV=1 to point the SDK at the local dev server (localhost:8288).
# Leave INNGEST_EVENT_KEY and INNGEST_SIGNING_KEY blank when using this.
# Start the dev server with: npx inngest-cli@latest dev -u http://localhost:3000/api/inngest
INNGEST_DEV=

# Alpaca (market data + broker)
# app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Google Gemini (primary LLM for all analyst nodes)
# aistudio.google.com → Get API key
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq (028-GROQ-CATALOGUE)
# console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# Stripe (024-STRIPE-TIER-ENFORCEMENT)
# STRIPE_SECRET_KEY       → dashboard.stripe.com → Developers → API keys → Secret key
# STRIPE_WEBHOOK_SECRET   → dashboard.stripe.com → Developers → Webhooks → add endpoint
#                           URL: https://atlas-broker-uat.vercel.app/api/webhooks/stripe
#                           Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
#                           Then copy the "Signing secret" shown after saving
# NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID → Stripe Dashboard → Products → create "Atlas Pro" → add Monthly price ($49) → copy price ID
# NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID  → same product → add Annual price ($39/mo = $468/yr) → copy price ID
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=

# App URL (used by MCP connector URL resolution — 026-MCP-INVESTOR-ROLLOUT)
# Set to the canonical deployment URL so the Claude connector shows the right endpoint
NEXT_PUBLIC_APP_URL=https://atlas-broker-uat.vercel.app
